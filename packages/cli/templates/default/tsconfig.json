{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types"],
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "hylo.config.ts"],
  "exclude": ["node_modules", ".hylo"]
}
