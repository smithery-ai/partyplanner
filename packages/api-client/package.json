{
  "name": "@hylo/api-client",
  "version": "0.0.1",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "pnpm run generate && tsc",
    "generate": "tsx scripts/generate-schema.ts && biome format --write --vcs-use-ignore-file=false src/generated/schema.d.ts",
    "prepack": "pnpm run build",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "openapi-fetch": "^0.15.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
