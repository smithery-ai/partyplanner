{
  "name": "hylo",
  "private": true,
  "bin": {
    "hylo": "./scripts/hylo.mjs"
  },
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "build": "turbo run build",
    "check": "biome ci --error-on-warnings .",
    "hylo": "node scripts/hylo.mjs",
    "dev": "pnpm hylo dev --backend node --workflow nextjs -- turbo run dev --filter=client --filter=workflow-nextjs-example --ui=tui",
    "fmt": "biome check --write --unsafe .",
    "prepare": "husky",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "husky": "^9.1.7",
    "portless": "^0.10.3",
    "tsx": "^4.21.0",
    "turbo": "^2.5.0"
  }
}
