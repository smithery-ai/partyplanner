{
  "name": "hylo",
  "private": true,
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "build": "turbo run build",
    "check": "biome ci --error-on-warnings .",
    "hylo": "tsx packages/cli/src/index.ts",
    "example": "rm -rf examples/sample && pnpm hylo init examples/sample && pnpm -C examples/sample install && pnpm -C examples/sample exec hylo deploy --backend ${HYLO_BACKEND_URL:-https://hylo-backend.smithery.workers.dev}",
    "dev": "node scripts/dev.mjs",
    "deploy:backend": "turbo run deploy --filter=backend-cloudflare",
    "deploy:app": "pnpm --filter client run deploy",
    "fmt": "biome check --write --unsafe .",
    "prepare": "husky",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "turbo": "^2.5.0",
    "vercel": "^51.8.0"
  }
}
