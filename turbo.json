{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "HYLO_BACKEND_NODE_DATA_DIR",
    "HYLO_BACKEND_URL",
    "PORTLESS",
    "PORTLESS_*",
    "VITE_BACKEND_URL",
    "SPOTIFY_CLIENT_ID",
    "SPOTIFY_CLIENT_SECRET",
    "OAUTH_STATE_SECRET",
    "NEXT_PUBLIC_APP_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
