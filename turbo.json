{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "HYLO_BACKEND_NODE_DATA_DIR",
    "HYLO_API_KEY",
    "HYLO_BACKEND_PUBLIC_URL",
    "HYLO_BROKER_BASE_URL",
    "HYLO_BACKEND_URL",
    "PORTLESS",
    "PORTLESS_*",
    "VITE_BACKEND_URL",
    "SPOTIFY_CLIENT_ID",
    "SPOTIFY_CLIENT_SECRET",
    "NOTION_CLIENT_ID",
    "NOTION_CLIENT_SECRET",
    "NOTION_PARENT_PAGE_ID",
    "NOTION_PAGE_ID",
    "OAUTH_STATE_SECRET",
    "NEXT_PUBLIC_APP_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "dev:local": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
