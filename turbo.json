{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["PORTLESS", "PORTLESS_*", "VITE_BACKEND_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
