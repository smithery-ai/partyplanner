{
  "name": "workflow-cloudflare-worker-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "hylo": {
    "workflow": {
      "id": "cloudflare-worker"
    },
    "dev": {
      "url": "https://cloudflare-worker.hylo.localhost"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "hylo dev --backend node -- wrangler dev --ip 127.0.0.1 --port '$PORT'",
    "deploy": "wrangler deploy --var HYLO_BACKEND_URL:$HYLO_BACKEND_URL",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@workflow/core": "workspace:*",
    "@workflow/runtime": "workspace:*",
    "@workflow/server": "workspace:*",
    "hono": "^4.12.14",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "hylo": "workspace:*",
    "typescript": "~6.0.2",
    "wrangler": "^4.53.0"
  }
}
