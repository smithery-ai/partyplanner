{
  "name": "workflow-cloudflare-worker-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "wrangler dev src/index.ts --name hylo-cloudflare-worker-example --compatibility-date 2026-04-19 --compatibility-flag global_fetch_strictly_public --ip 127.0.0.1 --port ${HYLO_CLOUDFLARE_WORKER_PORT:-8788} --inspector-port ${HYLO_CLOUDFLARE_WORKER_INSPECTOR_PORT:-9231} --var HYLO_BACKEND_URL:${HYLO_BACKEND_URL:-http://127.0.0.1:${HYLO_BACKEND_PORT:-8787}} --var INCIDENT_PUBLISHER_TOKEN:${INCIDENT_PUBLISHER_TOKEN:-local-dev-incident-publisher-token}",
    "deploy": "hylo deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@workflow/core": "workspace:*",
    "@workflow/integrations-notion": "workspace:*",
    "@workflow/integrations-oauth": "workspace:*",
    "@workflow/runtime": "workspace:*",
    "@workflow/server": "workspace:*",
    "hono": "^4.12.14",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@hylo/cli": "workspace:*",
    "typescript": "~6.0.2",
    "wrangler": "^4.53.0"
  }
}
