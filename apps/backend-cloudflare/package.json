{
  "name": "backend-cloudflare",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "hylo": {
    "backend": {
      "url": "http://127.0.0.1:8788"
    },
    "dev": {
      "url": "https://api-worker.hylo.localhost"
    }
  },
  "scripts": {
    "dev": "hylo dev --backend . -- wrangler dev --ip 127.0.0.1 --port '$PORT'",
    "deploy": "wrangler deploy",
    "db:generate": "pnpm -C ../../packages/cloudflare db:generate",
    "db:migrate": "pnpm -C ../../packages/cloudflare build && hylo exec --backend . -- wrangler d1 migrations apply hylo-backend --local",
    "db:migrate:remote": "pnpm -C ../../packages/cloudflare build && hylo exec --backend . -- wrangler d1 migrations apply hylo-backend --remote",
    "db:studio": "pnpm -C ../../packages/cloudflare build && hylo exec --backend . -- pnpm -C ../../packages/cloudflare exec tsx scripts/db-studio.ts",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@workflow/cloudflare": "workspace:*",
    "@workflow/core": "workspace:*",
    "@workflow/integrations-notion": "workspace:*",
    "@workflow/integrations-spotify": "workspace:*",
    "@workflow/oauth-broker": "workspace:*",
    "@workflow/remote": "workspace:*",
    "@workflow/runtime": "workspace:*",
    "@workflow/server": "workspace:*",
    "hono": "^4.12.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "hylo": "workspace:*",
    "typescript": "~6.0.2",
    "wrangler": "^4.0.0"
  }
}
