{
  "name": "backend-cloudflare",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "infisical export --path=/ --env=dev --format=dotenv > .dev.vars && infisical run --path=/ --env=dev -- wrangler dev --ip 127.0.0.1 --port ${HYLO_BACKEND_PORT:-8787} --inspector-port ${HYLO_BACKEND_INSPECTOR_PORT:-9230}",
    "deploy": "pnpm build && wrangler deploy --env production",
    "db:migrate": "pnpm -C ../../packages/postgres db:migrate",
    "db:migrate:dev": "infisical run --path=/ --env=dev -- pnpm db:migrate",
    "db:migrate:staging": "infisical run --path=/ --env=staging -- pnpm db:migrate",
    "db:migrate:prod": "infisical run --path=/ --env=prod -- pnpm db:migrate",
    "db:studio": "infisical run --path=/ --env=dev -- pnpm -C ../../packages/postgres db:studio",
    "db:studio:staging": "infisical run --path=/ --env=staging -- pnpm -C ../../packages/postgres db:studio",
    "db:studio:prod": "infisical run --path=/ --env=prod -- pnpm -C ../../packages/postgres db:studio",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@hylo/backend": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "~6.0.2",
    "wrangler": "^4.0.0"
  }
}
