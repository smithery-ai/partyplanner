{
  "name": "backend-cloudflare",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --ip 127.0.0.1 --port ${HYLO_BACKEND_PORT:-8787} --inspector-port ${HYLO_BACKEND_INSPECTOR_PORT:-9230}",
    "deploy": "pnpm build && wrangler deploy",
    "db:generate": "pnpm -C ../../packages/cloudflare db:generate",
    "db:migrate": "pnpm -C ../../packages/cloudflare build && wrangler d1 migrations apply hylo-backend --local",
    "db:migrate:remote": "pnpm -C ../../packages/cloudflare build && wrangler d1 migrations apply hylo-backend --remote",
    "db:studio": "pnpm -C ../../packages/cloudflare build && pnpm -C ../../packages/cloudflare exec tsx scripts/db-studio.ts",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@workflow/cloudflare": "workspace:*",
    "@workflow/core": "workspace:*",
    "@workflow/integrations-notion": "workspace:*",
    "@workflow/integrations-spotify": "workspace:*",
    "@workflow/oauth-broker": "workspace:*",
    "@workflow/remote": "workspace:*",
    "@workflow/runtime": "workspace:*",
    "@workflow/server": "workspace:*",
    "@hono/zod-openapi": "^1.3.0",
    "hono": "^4.12.14",
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "~6.0.2",
    "wrangler": "^4.0.0"
  }
}
