HYLO_API_KEY=local-dev-hylo-api-key

# Backend storage. In deployed environments prefer a HYPERDRIVE binding; for
# local dev you can also set POSTGRES_URL directly or use
# CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE in your shell.
POSTGRES_URL=

# WorkOS AuthKit. When WORKOS_CLIENT_ID is set, tenant-scoped routes accept
# WorkOS access tokens and derive tenant IDs from the selected org_id claim.
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_API_HOSTNAME=api.workos.com
# Optional public AuthKit API domain returned to browser and CLI clients.
# Keep WORKOS_API_HOSTNAME on api.workos.com if backend JWT verification should
# use the WorkOS API directly.
WORKOS_CLIENT_API_HOSTNAME=
WORKOS_ISSUER=
WORKOS_JWKS_URL=

# Workers for Platforms provisioning API. The API token needs Workers Scripts
# Write for the account that owns the dispatch namespace.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_DISPATCH_NAMESPACE=
CLOUDFLARE_WORKER_COMPATIBILITY_DATE=2026-04-19

# Optional. When set, POST /deployments derives workflowApiUrl as
# $HYLO_WORKER_DISPATCH_BASE_URL/:deploymentId/api/workflow unless the request
# provides workflowApiUrl explicitly.
HYLO_WORKER_DISPATCH_BASE_URL=

# Used to build OAuth redirect_uri values. The default is the Hylo dev backend
# URL, which is useful for providers like Notion that require HTTPS callbacks.
HYLO_BACKEND_PUBLIC_URL=https://api-worker.hylo.localhost

# Optional Hylo-curated OAuth providers. A provider is available only when both
# its client ID and client secret are present in this Worker environment.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
