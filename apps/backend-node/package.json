{
  "name": "backend-node",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "portless run --force --name api.hylo tsx src/index.ts",
    "dev:local": "tsx src/index.ts",
    "db:migrate": "HYLO_DB_APP=backend-node pnpm -C ../../packages/postgres db:migrate",
    "db:studio": "HYLO_DB_APP=backend-node pnpm -C ../../packages/postgres db:studio",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.14",
    "@hono/node-server": "^1.19.14",
    "@workflow/postgres": "workspace:*",
    "@workflow/remote": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.14"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2"
  }
}
