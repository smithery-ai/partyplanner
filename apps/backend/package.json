{
  "name": "backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "portless run --force --name api-worker.hylo node scripts/dev.mjs",
    "dev:local": "node scripts/dev.mjs",
    "db:generate": "pnpm -C ../../packages/cloudflare db:generate",
    "db:migrate": "pnpm -C ../../packages/cloudflare db:migrate",
    "db:migrate:remote": "pnpm -C ../../packages/cloudflare db:migrate:remote",
    "db:studio": "pnpm -C ../../packages/cloudflare db:studio",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@workflow/cloudflare": "workspace:*",
    "@workflow/core": "workspace:*",
    "@workflow/integrations-notion": "workspace:*",
    "@workflow/integrations-spotify": "workspace:*",
    "@workflow/oauth-broker": "workspace:*",
    "@workflow/remote": "workspace:*",
    "@workflow/runtime": "workspace:*",
    "@workflow/server": "workspace:*",
    "hono": "^4.12.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "wrangler": "^4.0.0",
    "typescript": "~6.0.2"
  }
}
